{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vovonacci Reader",
  "version": "0.3.6",
  "identifier": "com.vovonacci.reader",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "vovonacci · READER",
        "width": 1280,
        "height": 1000,
        "minWidth": 720,
        "minHeight": 520,
        "center": true,
        "backgroundColor": "#0a0a0b"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/pxpc2/vovonacci-reader/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCM0JENjkxMjIwNzJCRTIKUldUaUt3Y2lrZFk3SzRXalpmdEdmMjdvZ2ZQelBlVkJsUmZGVEVRUlJSVytibDFVeTJjV013M1UK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "PDF Document",
        "description": "Portable Document Format",
        "role": "Viewer"
      }
    ]
  }
}
